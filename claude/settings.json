      "Bash(command *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(xargs *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash*)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git tag *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git config *)",
      "Bash(git clone *)",
      "Bash(git sparse-checkout *)",
      "Bash(git -C *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(gh *)",
      "Bash(ghq *)",
      "Bash(gwq *)",
      "Bash(proto *)",
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(bun *)",
