{
  "permissions": {
    "allow": [
      "Read(*)",
      "List(*)",
      "Fetch(https://*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(mv:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(jq:*)",
      "Bash(which:*)",
      "Bash(whereis:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(proto:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(bun:*)",
      "Bash(uv:*)",
      "Bash(rye:*)",
      "Bash(python:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(task:*)",
      "Bash(biome:*)",
      "Bash(actionlint:*)",
      "mcp__github__*",
      "mcp__filesystem__*"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(sudo rm:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Read(.env*)",
      "Read(**/credentials*)",
      "Read(**/*secret*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)"
    ]
  }
}
