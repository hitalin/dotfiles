{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "language": "ja",
  "cleanupPeriodDays": 30,
  "showTurnDuration": true,
  "statusLine": {
    "command": "\"$HOME/.claude/hooks/statusline.sh\"",
    "timeout": 3000
  },

  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },

  "attribution": {
    "commit": "\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>"
  },

  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:zenn.dev)",
      "WebFetch(domain:developer.mozilla.org)",

      "Bash(*--help*)",
      "Bash(*--version*)",

      "Bash(ls *)",
      "Bash(mv *)",
      "Bash(make *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(ln *)",
      "Bash(touch *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(diff *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(tee *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(which *)",
      "Bash(whereis *)",
      "Bash(command *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(rg *)",
      "Bash(fd *)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash*)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git tag *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git config *)",
      "Bash(git clone *)",
      "Bash(gh *)",
      "Bash(ghq *)",
      "Bash(gwq *)",

      "Bash(proto *)",
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(node *)",

      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(rye *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pytest *)",

      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(rustup *)",

      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(podman *)",

      "Bash(task *)",
      "Bash(just *)",

      "Bash(biome *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(actionlint *)",
      "Bash(shellcheck *)",
      "Bash(shfmt *)",
      "Bash(ruff *)",
      "Bash(gofmt *)",
      "Bash(rustfmt *)",

      "Bash(zoxide *)",
      "Bash(fzf *)",
      "Bash(bat *)",
      "Bash(batcat *)",
      "Bash(eza *)",
      "Bash(tree *)",

      "mcp__github__*",
      "mcp__filesystem__*",

      "Skill(commit)",
      "Skill(review-pr)",
      "Skill(test)",
      "Skill(fix-issue)",
      "Skill(security-audit)",
      "Skill(refactor)",
      "Skill(deps)",
      "Task(Explore)",
      "Task(Plan)"
    ],

    "ask": [
      "Bash(git push *)",
      "Bash(rm *)"
    ],

    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",

      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(**/credentials*)",
      "Edit(**/credentials*)",
      "Write(**/credentials*)",
      "Read(**/*secret*)",
      "Edit(**/*secret*)",
      "Write(**/*secret*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)",
      "Read(**/.gnupg/*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/pre-bash-secret-guard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/post-compact-reminder.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/post-edit-format.sh\"",
            "timeout": 30000,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/stop-uncommitted-reminder.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/subagent-context-inject.sh\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -u normal 'Claude Code' '入力待ちです' 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
