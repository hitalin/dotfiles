{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },
  "attribution": {
    "commit": "\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>"
  },
  "permissions": {
    "allow": [
