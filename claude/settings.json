      "Bash(pip *)",
      "Bash(pytest *)",
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(rustup *)",
      "Bash(dotnet *)",
      "Bash(nix *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(podman *)",
      "Bash(task *)",
      "Bash(just *)",
      "Bash(biome *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(actionlint *)",
      "Bash(shellcheck *)",
      "Bash(shfmt *)",
      "Bash(ruff *)",
      "Bash(gofmt *)",
      "Bash(rustfmt *)",
      "Bash(zoxide *)",
      "Bash(fzf *)",
      "Bash(bat *)",
      "Bash(batcat *)",
      "Bash(eza *)",
      "Bash(tree *)",
      "Bash(source *)",
      "Bash(export *)",
      "Bash(SOPS_AGE_KEY_FILE=*)",
      "mcp__github__*",
      "mcp__filesystem__*",
      "Skill(commit)",
      "Skill(review-pr)",
      "Skill(test)",
      "Skill(fix-issue)",
      "Skill(security-audit)",
      "Skill(refactor)",
      "Skill(deps)",
      "Task(Explore)",
      "Task(Plan)",
      "Read(//home/taka/**)",
      "Read(//tmp/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(**/credentials*)",
      "Edit(**/credentials*)",
      "Write(**/credentials*)",
      "Read(**/*secret*)",
      "Edit(**/*secret*)",
      "Write(**/*secret*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)",
      "Read(**/.gnupg/*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm *)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/home/taka/.ghq/github.com/hitalin/notedeck/src/{adapters/misskey,adapters/sharkey,adapters/cherrypick,core,stores,composables,components",
      "/tmp/notedeck-init/public",
      "/home/taka/.claude/projects/-home-taka--ghq-github-com-hitalin-notedeck"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/pre-bash-credential-guard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/post-compact-reminder.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/post-edit-format.sh\"",
            "timeout": 30000,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/stop-uncommitted-reminder.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/subagent-context-inject.sh\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -u normal 'Claude Code' '入力待ちです' 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"$HOME/.claude/hooks/statusline.sh\""
  },
  "language": "ja",
  "showTurnDuration": true
}
