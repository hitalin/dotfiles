{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },
  "attribution": {
    "commit": "\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Task",
      "mcp__github__*",
      "mcp__filesystem__*",
      "mcp__claude_ai_*",
      "Bash(curl -s \"https://raw.githubusercontent.com/HanaMisskey/misskey/hanami/packages/backend/src/server/api/stream/ChannelsService.ts\")",
      "Read(//home/taka/.cargo/git/checkouts/notecli-87329c01dfbd0d2a/df3dff1/src/**)",
      "Read(//home/taka/.ghq/github.com/hitalin/notecli/src/**)",
      "Read(//home/taka/.ghq/github.com/hitalin/notecli/**)",
      "Read(//home/taka/.ghq/github.com/misskey-dev/misskey/packages/frontend/src/ui/_common_/**)",
      "Read(//home/taka/.ghq/github.com/hitalin/notedeck/**)",
      "Read(//home/taka/.cargo/git/checkouts/notecli-87329c01dfbd0d2a/01637d7/src/**)",
      "Read(//home/taka/.cargo/git/checkouts/notecli-87329c01dfbd0d2a/d4e8512/src/**)",
      "Read(//home/taka/.cargo/git/checkouts/notecli-87329c01dfbd0d2a/0f54eb7/src/**)",
      "Read(//home/taka/.cargo/git/checkouts/notecli-87329c01dfbd0d2a/9f76da6/src/**)",
      "Read(//home/taka/.cargo/git/checkouts/notecli-87329c01dfbd0d2a/5af7468/src/**)",
      "Read(//home/taka/.ghq/github.com/yamisskey-dev/yamisskey/packages/frontend/src/components/**)",
      "Read(//home/taka/.ghq/github.com/yamisskey-dev/yamisskey/packages/frontend/src/**)",
      "Read(//home/taka/.ghq/github.com/yamisskey-dev/yamisskey/packages/backend/src/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(**/credentials*)",
      "Edit(**/credentials*)",
      "Write(**/credentials*)",
      "Read(**/*secret*)",
      "Edit(**/*secret*)",
      "Write(**/*secret*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)",
      "Read(**/.gnupg/*)"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/home/taka/.ghq/github.com/hitalin/notedeck/src/{adapters/misskey,adapters/sharkey,adapters/cherrypick,core,stores,composables,components",
      "/tmp/notedeck-init/public",
      "/home/taka/.claude/projects/-home-taka--ghq-github-com-hitalin-notedeck"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/pre-bash-credential-guard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/post-compact-reminder.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/post-edit-format.sh\"",
            "timeout": 30000,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/stop-uncommitted-reminder.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/subagent-context-inject.sh\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -u normal 'Claude Code' '入力待ちです' 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"$HOME/.claude/hooks/statusline.sh\""
  },
  "language": "ja",
  "showTurnDuration": true
}
