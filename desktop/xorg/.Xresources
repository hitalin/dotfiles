!-------------------------------------------------------------------------------
! Xft settings
!-------------------------------------------------------------------------------
Xft.dpi:       96
Xft.antialias: true
Xft.rgba:      rgb
Xft.hinting:   true
Xft.hintstyle: hintslight


!-------------------------------------------------------------------------------
! Common settings between Xterm and URxvt
!-------------------------------------------------------------------------------
*background:   #000000
*foreground:   #B2B2B2

!-------------------------------------------------------------------------------
! URxvt settings
!-------------------------------------------------------------------------------

! color
URxvt.fading:  40
! Linux default theme
!! black
URxvt*color0:  #000000
URxvt*color8:  #686868
!! red
URxvt*color1:  #B21818
URxvt*color9:  #FF5454
!! green
URxvt*color2:  #18B218
URxvt*color10: #54FF54
!! yellow
URxvt*color3:  #B26818
URxvt*color11: #FFFF54
!! blue
URxvt*color4:  #1818B2
URxvt*color12: #5454FF
!! purple
URxvt*color5:  #B218B2
URxvt*color13: #FF54FF
!! cyan
URxvt*color6:  #18B2B2
URxvt*color14: #54FFFF
!! white
URxvt*color7:  #B2B2B2
URxvt*color15: #FFFFFF

! scrollbar
URxvt.scrollBar_right: true
URxvt.scrollStyle:     plain

! transparent
urxvt*depth: 32
urxvt*background: rgba:0000/0000/0200/c800

! font
URxvt.font:     xft:Cica:size=11:antialias=true, \
                xft:DejaVu Sans Mono:size=11
URxvt.boidFont: xft:Cica:size=12:antialias=true

! URxvt-perls
URxvt.perl-lib:        /lib64/urxvt/perl/
URxvt.perl-ext-common: default,selection-to-clipboard,osc-xterm-clipboard,matcher,tabbed,xim-onthespot
!! matcher
!URxvt.perl-ext-common: matcher
URxvt.url-launcher:    /usr/bin/firefox
URxvt.matcher.button:   1
!! tabbed
!URxvt.perl-ext-common:  tabbed
URxvt.tabbed.tabbar-fg: 2
URxvt.tabbed.tabbar-bg: #001020
URxvt.tabbed.tab-fg:    3
URxvt.tabbed.tab-bg:    #001020
URxvt.tabbed.tabbar-fg: 2
URxvt.tabbed.tabbar-bg: #001020
URxvt.tabbed.tab-fg:    3
URxvt.tabbed.tab-bg:    #001020
!! xim-onthespot
!URxvt.perl-ext-common: xim-onthespot
URxvt.inputMethod:     fcitx
URxvt.preeditType:     OnTheSpot
