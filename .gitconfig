[user]
	name = i0z0m
	email = i0z0m.prog@gmail.com

[core]
	editor = vim -c \"set fenc=utf-8\"
	quotepath = false
	ignorecase = false
	excludesfile = /home/taka/.gitignore_global

[color]
	ui = true
	diff = auto
	status = auto
	branch = auto

[merge]
  tool = vimdiff
  keepBackup = false
  conflictStyle = diff3

[ghq]
  vcs = git
  root = ~/projects
