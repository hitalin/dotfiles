"" General Configuration
colorscheme scheme
set focuscontent
set status=input,ssl,location,bookmark,history,tabcount,position
set gui=noaddons,nobookmarks,nomenu,nonavigation,tabs
set! browser.startup.homepage=about:newtab
set! toolkit.scrollbox.verticalScrollDistance=10

javascript << EOS
(function () {
  if (!liberator.has("Windows")) {
    liberator.execute("set editor=\"urxvt -e emacs\"");
  }
}());
EOS


"" Keymap for Normal/Visual Mode
noremap j <Down>
noremap k <Up>
noremap <C-h> <Nop>
noremap <C-r> :mapc<CR>:cmapc<CR>:imapc<CR>:highlight clear<CR>:source ~/.vimperatorrc<CR>
noremap <A-n> :tabmove +1<CR>
noremap <A-p> :tabmove -1<CR>

javascript << EOS
(function () {
  if (liberator.has("Windows")) {
    liberator.execute("noremap o :open google<SPACE>");
    liberator.execute("noremap t :tabopen google<SPACE>");
    liberator.execute("noremap <C-l> :open<SPACE>");
    liberator.execute("noremap B :bmarks -tags<SPACE>");
    var style = "style -name commandline-ime chrome://* " +
                "#liberator-commandline-command input { ime-mode: inactive; }";
    liberator.execute(style);
  } else {
    liberator.execute("command! disableime silent !xdotool key Ctrl+Shift+space");
    liberator.execute("noremap f :disableime<CR>;o");
    liberator.execute("noremap o :disableime<CR>:open google<SPACE>");
    liberator.execute("noremap t :disableime<CR>:tabopen google<SPACE>");
    liberator.execute("noremap <C-l> :disableime<CR>:open<SPACE>");
    liberator.execute("noremap F :disableime<CR>;t");
    liberator.execute("noremap B :disableime<CR>:bmarks -tags<SPACE>");
    liberator.execute("noremap / :disableime<CR>/");
    liberator.execute("noremap : :disableime<CR>:");
  }
}());
EOS


