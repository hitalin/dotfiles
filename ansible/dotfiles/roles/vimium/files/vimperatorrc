"" Install Addons
javascript << EOS
(function () {
  var installAddon = function(name, url) {
    if (!liberator.hasExtension(name)) {
      if (liberator.has("Windows")) {
        // Not Implemented
      } else {
        var local = "/tmp/" + name + ".xpi";
        liberator.execute("silent !wget -O " + local + " " + url);
        liberator.execute("extadd " + local);
      }
    }
  };

  var addonURL = function(path) {
    return "https://addons.mozilla.org/firefox/downloads/" + path;
  };

  if (liberator.profileName == "default") {
    installAddon("Xmarks"      , addonURL("latest/2410/addon-2410-latest.xpi"));
    installAddon("Brief"       , addonURL("latest/4578/addon-4578-latest.xpi"));
    installAddon("ツリー型タブ", addonURL("file/380123/tree_style_tab-0.16.2015122501-fx.xpi"));
    installAddon("LastPass"    , addonURL("latest/8542/addon-8542-latest.xpi"));
  }
}());
EOS


"" TreeStyleTab Configuration
javascript << EOS
(function () {
  if (liberator.hasExtension("ツリー型タブ")) {
    liberator.execute("set! extensions.treestyletab.closeParentBehavior=0");
    liberator.execute("set! extensions.treestyletab.closeRootBehavior=1");
    liberator.execute("set! extensions.treestyletab.autoCollapseExpandSubtreeOnAttach=false");
    liberator.execute("set! extensions.treestyletab.tabbar.fixed.vertical=true");
    liberator.execute("set! extensions.treestyletab.tabbar.style=mixed");
    liberator.execute("set! extensions.treestyletab.tabbar.position=left");
    liberator.execute("set! extensions.treestyletab.tabbar.width.default=203");
  }
}());
EOS


